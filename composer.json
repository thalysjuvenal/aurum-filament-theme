{
    "name": "thalysjuvenal/aurum-filament-theme",
    "description": "Aurum — executive gold/graphite theme plugin for FilamentPHP v5 panels",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "filament",
        "filamentphp",
        "theme",
        "laravel",
        "dark-sidebar"
    ],
    "authors": [
        {
            "name": "Thalys Juvenal"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "ThalysJuvenal\\Aurum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThalysJuvenal\\Aurum\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ThalysJuvenal\\Aurum\\AurumThemeServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": "pest",
        "lint": "pint --test",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
